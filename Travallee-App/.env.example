# ============================================
# Travallee Mobile App Environment Variables
# ============================================
# For deployment, copy to .env and update values
# Note: Use your deployment domain for production, not localhost

# ============================================
# API CONFIGURATION
# ============================================
# For local development with physical device: http://your-machine-ip:4000/api/v1
# For production: https://yourdomain.com/api/v1
API_BASE_URL=https://yourdomain.com/api/v1

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# APP CONFIGURATION
# ============================================
EXPO_PUBLIC_APP_NAME=Travallee
EXPO_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

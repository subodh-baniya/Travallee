# ============================================
# Notifications Service Environment Variables
# ============================================
# For deployment, copy to .env and update values

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://db:27017
MONGODB_DB_NAME=notifications

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=6000
NODE_ENV=production

# ============================================
# CACHE CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# EMAIL CONFIGURATION - RESEND API (Recommended)
# ============================================
RESEND_API=your-resend-api-key

# ============================================
# EMAIL CONFIGURATION - GMAIL (Alternative)
# ============================================
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ============================================
# CORS CONFIGURATION
# ============================================
CLIENT_URL=https://yourdomain.com

# ============================================
# Root Environment File for Docker Compose
# ============================================
# Copy this to .env and update production values

# ============================================
# DATABASE & CACHE
# ============================================
MONGO_URI=mongodb://db:27017
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# AUTH SERVICE
# ============================================
PORT_AUTH=3000
AUTH_DB_NAME=authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================
# ADMIN SERVICE
# ============================================
PORT_ADMIN=4001
ADMIN_DB_NAME=adminDB

# ============================================
# BOOKING SERVICE
# ============================================
PORT_BOOKING=5002
BOOKING_DB_NAME=booking

# ============================================
# HOTEL SERVICE
# ============================================
PORT_HOTEL=3001
HOTEL_DB_NAME=ghumgham

# ============================================
# NOTIFICATIONS SERVICE
# ============================================
PORT_NOTIFICATIONS=6000
NOTIFICATIONS_DB_NAME=notifications

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Resend API (Recommended for production)
RESEND_API=your-resend-api-key

# Gmail Configuration (Alternative)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ============================================
# FILE STORAGE (Cloudinary)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# User Frontend Environment Variables
# For deployment, copy to .env.local and update values

# ============================================
# API CONFIGURATION
# ============================================
VITE_API_BASE_URL=http://localhost:5002/api/v1
VITE_AUTH_API_BASE_URL=http://localhost:3000/api/v1/users
VITE_API_BASE_URL_HOTEL=http://localhost:3001/api/v1/hotels
VITE_API_BASE_URL_BOOKING=http://localhost:5002/api/v1/bookings
VITE_API_BASE_URL_ADMIN=http://localhost:4001

# ============================================
# ENVIRONMENT
# ============================================
VITE_ENV=production

# ============================================
# APP CONFIGURATION
# ============================================
VITE_APP_NAME=Travallee
VITE_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_NOTIFICATIONS=true
# VITE_ENABLE_CHAT=true